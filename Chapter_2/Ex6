#include <stdio.h>

float quarts_water = 0.950;
float molecular = 3.0e-23;
float molecular_count;
float quarts;

int main(void){
    printf("Введите количество кварт: ");
    scanf("%f", &quarts);
    molecular_count = (quarts * quarts_water)/molecular;
    printf("Это %f молекул\n", molecular_count);
    return 0;
}
